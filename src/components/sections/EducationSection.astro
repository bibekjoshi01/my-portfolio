---
import type { EducationItem } from "@data/resume";

const { title, items } = Astro.props as {
  title: string;
  items: EducationItem[];
};
---

<section
  class="space-y-4 rounded-3xl border border-slate-200 bg-white/60 px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/60 sm:px-8"
>
  <div class="flex flex-col gap-1">
    <p
      class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-700 dark:text-sky-300"
    >
      {title}
    </p>
  </div>

  <div class="space-y-5">
    {
      items.map((item) => (
        <article class="rounded-2xl border border-slate-200 bg-slate-50/70 p-5 dark:border-slate-800 dark:bg-slate-900/40">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
            <div>
              <p class="text-lg font-semibold text-slate-900 dark:text-slate-100">
                {item.degree}
              </p>
              <p class="text-sm font-medium text-slate-500 dark:text-slate-400">
                {item.institution}
                {item.location ? ` · ${item.location}` : ""}
              </p>
            </div>
            <span class="text-sm font-medium text-slate-500 dark:text-slate-400">
              {item.duration}
            </span>
          </div>
          {item.highlights && (
            <ul class="mt-3 space-y-1 text-sm text-slate-600 dark:text-slate-300">
              {item.highlights.map((line) => (
                <li class="flex gap-2">
                  <span class="mt-1 h-1.5 w-1.5 rounded-full bg-slate-500" />
                  <span>{line}</span>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))
    }
  </div>
</section>
