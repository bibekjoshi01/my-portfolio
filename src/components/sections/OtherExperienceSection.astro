---
import type { OtherExperienceEntry } from "@data/resume";

const { title, items } = Astro.props as {
  title: string;
  items: OtherExperienceEntry[];
};
---

<section
  class="reading-surface space-y-6 rounded-3xl border border-slate-200 bg-white/80 px-6 py-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/70 sm:px-8"
>
  <div class="flex flex-col gap-1">
    <p
      class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-700 dark:text-sky-300"
    >
      {title}
    </p>
  </div>

  <div class="space-y-5">
    {
      items.map((entry) => (
        <article class="rounded-2xl border border-slate-200 bg-slate-50/70 p-5 dark:border-slate-800 dark:bg-slate-900/40">
          <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-50">
            {entry.title}
          </h3>
          <p class="text-sm text-slate-600 dark:text-slate-300">
            {entry.summary}
          </p>
          <ul class="mt-3 space-y-1 text-sm text-slate-600 dark:text-slate-300">
            {entry.highlights.map((point) => (
              <li class="flex items-start gap-2">
                <span class="mt-1 h-1.5 w-1.5 rounded-full bg-slate-500 dark:bg-slate-400" />
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </article>
      ))
    }
  </div>
</section>
